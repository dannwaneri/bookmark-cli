# X/Twitter session credentials
# To get these values:
#   1. Log in to x.com and go to x.com/i/bookmarks
#   2. Open DevTools (F12) -> Network tab -> filter by "Bookmarks"
#   3. Click the Bookmarks request -> Headers tab
#   4. Copy the values below from the Request Headers section

# The ct0 cookie value (also used as X-Csrf-Token)
CT0=your_ct0_value_here

# The auth_token cookie value
AUTH_TOKEN=your_auth_token_value_here

# The full Cookie header string (copy the entire cookie: line from DevTools)
# This includes ct0, auth_token, kdt, twid, guest_id, and other session cookies
COOKIE=guest_id=v1%3A...; auth_token=...; ct0=...; kdt=...; twid=u%3D...

# Likes sync (optional — required for sync-likes)
# Get this hash from DevTools while on x.com/{yourhandle}/likes (Network tab → Likes request URL)
LIKES_HASH=your_likes_hash_here

# Vectorize worker (optional — required for semantic-hooks and ingest-vector)
# Deploy https://github.com/dannwaneri/vectorize-mcp-worker to get these
VECTORIZE_URL=https://your-worker.workers.dev
VECTORIZE_API_KEY=your_api_key_here
